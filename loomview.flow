// === Simulation Mode ===

// Note: viz_sim with callback not supported — use recipes directly.
// Each recipe (recipe_heat, recipe_wave, etc.) has its own run() function
// with integrated stepping, transport controls, and recording.

// === Recipe Mode ===

fn viz_recipe(name)
  if name == "heat"
    print("LoomView: loading heat diffusion recipe")
    print("  Use: use \"recipes/recipe_heat\"")
    print("       recipe_heat_run(40, 30)")
    return 1.0
  elif name == "wave"
    print("LoomView: loading wave propagation recipe")
    print("  Use: use \"recipes/recipe_wave\"")
    print("       recipe_wave_run(40, 30)")
    return 1.0
  elif name == "nbody"
    print("LoomView: loading N-body simulation recipe")
    print("  Use: use \"recipes/recipe_nbody\"")
    print("       recipe_nbody_run(50)")
    return 1.0
  elif name == "mandelbrot"
    print("LoomView: loading Mandelbrot fractal recipe")
    print("  Use: use \"recipes/recipe_mandelbrot\"")
    print("       recipe_mandelbrot_run()")
    return 1.0
  elif name == "sort"
    print("LoomView: loading sorting race recipe")
    print("  Use: use \"recipes/recipe_sort_viz\"")
    print("       recipe_sort_run(80)")
    return 1.0
  elif name == "fft"
    print("LoomView: loading FFT spectrogram recipe")
    print("  Use: use \"recipes/recipe_fft_viz\"")
    print("       recipe_fft_run()")
    return 1.0
  end
  print("viz_recipe: unknown recipe '{name}'")
  print("  Available: heat, wave, nbody, mandelbrot, sort, fft")
  return 0.0
end

// === Utility ===

fn viz_describe(data)
  let n = len(data)
  if n == 0.0
    print("viz_describe: empty data")
    return 0.0
  end

  let fp = viz_fingerprint(data)
  let best = viz_best(data)
  let scores = viz_score(fp)

  print("=== LoomView Data Summary ===")
  print("  Length:     {fp[0]}")
  print("  Range:      [{fp[1]}, {fp[2]}]")
  print("  Mean:       {fp[3]}")
  print("  Std Dev:    {fp[4]}")
  print("  Skewness:   {fp[5]}")
  print("  Sparsity:   {fp[6]}")
  print("  Monotonic:  {fp[10]}")
  print("  Entropy:    {fp[11]}")
  print("  Integer:    {fp[12]}")
  print("  Binary:     {fp[13]}")
  print("  Bounded01:  {fp[14]}")
  print("  UniqueRatio:{fp[15]}")
  print("")
  let best_name = viz_type_name(best)
  print("  Best viz: {best_name}")
  print("  Scores: line={scores[0]} scatter={scores[1]} bar={scores[2]} heat={scores[3]}")
  print("          hist={scores[4]} pie={scores[5]} spark={scores[6]}")

  return best
end
