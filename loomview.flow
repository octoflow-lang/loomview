// loomview.flow — LoomView v0.2 Entry Point
//
// GPU-accelerated data visualization for OctoFlow.
// One import, one function call -> instant adaptive visualization.
//
// Auto Mode:
//   use "loomview"
//   viz_show([1.0, 4.0, 2.0, 8.0, 5.0, 7.0])
//
// Explicit Mode:
//   viz_line(data)
//   viz_bar(data)
//   viz_heat(data, 40, 30)
//   viz_scatter(xy_data)
//
// Recipe Mode:
//   viz_recipe("heat")

use "src/data"
use "src/config"
use "src/render"
use "src/app"
use "src/palette"
use "src/controls"
use "src/recorder"

// === Auto Mode: one-liner ===

fn viz_show(data)
  let n = len(data)
  if n == 0.0
    print("viz_show: empty data, nothing to display")
    return 0.0
  end

  let viz_type = viz_best(data)
  let config = viz_auto_config(data, viz_type)
  let type_name = viz_type_name(viz_type)

  print("LoomView: auto-selected {type_name} for {n} data points")

  let _cvs = app_open("LoomView - " + type_name, 1000.0, 700.0)
  app_add_record_button()
  let _r = app_update(data, viz_type, config)
  let _l = app_loop(0)
  return 1.0
end

// === Explicit Mode ===

fn viz_line(data)
  let n = len(data)
  if n < 2.0
    print("viz_line: need at least 2 data points")
    return 0.0
  end

  let config = viz_auto_config(data, VIZ_LINE)
  let _cvs = app_open("LoomView - Line", 1000.0, 700.0)
  app_add_record_button()
  let _r = app_update(data, VIZ_LINE, config)
  let _l = app_loop(0)
  return 1.0
end

fn viz_bar(data)
  let n = len(data)
  if n == 0.0
    print("viz_bar: empty data")
    return 0.0
  end

  let config = viz_auto_config(data, VIZ_BAR)
  let _cvs = app_open("LoomView - Bar", 1000.0, 700.0)
  app_add_record_button()
  let _r = app_update(data, VIZ_BAR, config)
  let _l = app_loop(0)
  return 1.0
end

fn viz_scatter(xy_data)
  let n = len(xy_data)
  if n < 4.0
    print("viz_scatter: need at least 2 points (4 values)")
    return 0.0
  end
  if floor(n / 2.0) * 2.0 != n
    print("viz_scatter: data length must be even (x,y pairs)")
    return 0.0
  end

  let config = viz_auto_config(xy_data, VIZ_SCATTER)
  let _cvs = app_open("LoomView - Scatter", 1000.0, 700.0)
  app_add_record_button()
  let _r = app_update(xy_data, VIZ_SCATTER, config)
  let _l = app_loop(0)
  return 1.0
end

fn viz_heat(data, w, h)
  let n = len(data)
  if n == 0.0
    print("viz_heat: empty data")
    return 0.0
  end
  if w <= 0.0 || h <= 0.0
    print("viz_heat: width and height must be positive")
    return 0.0
  end
  if n < w * h
    print("viz_heat: warning — data length {n} < {w} * {h}, will show partial")
  end

  let mut config = viz_auto_config(data, VIZ_HEATMAP)
  config[5] = w
  config[6] = h

  let _cvs = app_open("LoomView - Heatmap", 1000.0, 700.0)
  app_add_transport()
  app_add_record_button()
  let _r = app_update(data, VIZ_HEATMAP, config)
  let _l = app_loop(0)
  return 1.0
end

fn viz_histogram(data, bins)
  let n = len(data)
  if n == 0.0
    print("viz_histogram: empty data")
    return 0.0
  end

  let mut b = bins
  if b <= 0.0
    b = 10.0
  end

  let mut config = viz_auto_config(data, VIZ_HISTOGRAM)
  config[7] = b

  let _cvs = app_open("LoomView - Histogram", 1000.0, 700.0)
  app_add_record_button()
  let _r = app_update(data, VIZ_HISTOGRAM, config)
  let _l = app_loop(0)
  return 1.0
end

