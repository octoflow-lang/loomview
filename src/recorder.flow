// recorder.flow — Frame Capture + Export Orchestration
//
// Records visualization frames for export as GIF, HTML, or CSV.
// Captures canvas framebuffer snapshots at configurable FPS.
//
// Usage:
//   use "src/recorder"
//   recorder_start(10.0)          // 10 FPS
//   // ... render frames, call recorder_capture() each frame ...
//   recorder_stop()

// === Recorder State ===
// Uses single-element arrays for cross-module mutation visibility.
// (Scalar writeback doesn't propagate across imported module boundaries.)
let mut _rec_active = [0.0]
let mut _rec_fps = [10.0]
let mut _rec_frame_count = [0.0]
let mut _rec_width = [0.0]
let mut _rec_height = [0.0]
let mut _rec_last_capture_ms = [0.0]
let mut _rec_interval_ms = [100.0]

// Frame storage: flat array of all frames concatenated
let mut _rec_frames = []

// Timestamps per frame
let mut _rec_timestamps = []

// Offset tracking for multi-session support
let mut _rec_frame_offset = [0.0]
let mut _rec_ts_offset = [0.0]

// Maximum frames to prevent memory exhaustion
let REC_MAX_FRAMES = 3600.0

fn recorder_start(fps)
  let mut f = fps
  if f <= 0.0
    f = 10.0
  end
  if f > 60.0
    f = 60.0
  end
  _rec_fps[0] = f
  _rec_interval_ms[0] = 1000.0 / f
  _rec_active[0] = 1.0
  _rec_frame_offset[0] = len(_rec_frames)
  _rec_ts_offset[0] = len(_rec_timestamps)
  _rec_frame_count[0] = 0.0
  _rec_last_capture_ms[0] = 0.0
  print("Recorder: started at {f} FPS")
  return 1.0
end

fn recorder_stop()
  _rec_active[0] = 0.0
  let fc = _rec_frame_count[0]
  print("Recorder: stopped. {fc} frames captured.")
  return fc
end

fn recorder_is_active()
  return _rec_active[0]
end

fn recorder_frame_count()
  return _rec_frame_count[0]
end

fn recorder_capture_rgb(r_buf, g_buf, b_buf, width, height, timestamp_ms)
  if _rec_active[0] == 0.0
    return 0.0
  end

  if _rec_frame_count[0] >= REC_MAX_FRAMES
    return 0.0
  end

  if width <= 0.0 || height <= 0.0
    return 0.0
  end

  // Rate limiting
  if _rec_frame_count[0] > 0.0
    let elapsed = timestamp_ms - _rec_last_capture_ms[0]
    if elapsed < _rec_interval_ms[0]
      return 0.0
    end
  end

  let n_pixels = width * height
  if len(r_buf) < n_pixels || len(g_buf) < n_pixels || len(b_buf) < n_pixels
    return 0.0
  end

  _rec_width[0] = width
  _rec_height[0] = height

  // Append frame data (interleaved RGB)
  let mut i = 0.0
  while i < n_pixels
    push(_rec_frames, r_buf[int(i)])
    push(_rec_frames, g_buf[int(i)])
    push(_rec_frames, b_buf[int(i)])
    i = i + 1.0
  end

  push(_rec_timestamps, timestamp_ms)
  _rec_frame_count[0] = _rec_frame_count[0] + 1.0
  _rec_last_capture_ms[0] = timestamp_ms

  return 1.0
end

fn recorder_capture_interleaved(rgb_buf, width, height, timestamp_ms)
  if _rec_active[0] == 0.0
    return 0.0
  end

  if _rec_frame_count[0] >= REC_MAX_FRAMES
    return 0.0
  end

  if width <= 0.0 || height <= 0.0
    return 0.0
  end

  if _rec_frame_count[0] > 0.0
    let elapsed = timestamp_ms - _rec_last_capture_ms[0]
    if elapsed < _rec_interval_ms[0]
      return 0.0
    end
  end

  let n_pixels = width * height
  if len(rgb_buf) < n_pixels * 3.0
    return 0.0
  end

  _rec_width[0] = width
  _rec_height[0] = height

  let mut i = 0.0
  while i < n_pixels * 3.0
    push(_rec_frames, rgb_buf[int(i)])
    i = i + 1.0
  end

  push(_rec_timestamps, timestamp_ms)
  _rec_frame_count[0] = _rec_frame_count[0] + 1.0
  _rec_last_capture_ms[0] = timestamp_ms

  return 1.0
end

fn recorder_get_frame(frame_idx)
  if frame_idx < 0.0 || frame_idx >= _rec_frame_count[0]
    let mut empty = []
    return empty
  end

  let n_pixels = _rec_width[0] * _rec_height[0]
  let frame_size = n_pixels * 3.0
  let offset = int(_rec_frame_offset[0] + frame_idx * frame_size)

  let mut frame = []
  let mut i = 0.0
  while i < frame_size
    if offset + int(i) < len(_rec_frames)
      push(frame, _rec_frames[offset + int(i)])
    end
    i = i + 1.0
  end

  return frame
end

fn recorder_get_dimensions()
  let mut dims = []
  push(dims, _rec_width[0])
  push(dims, _rec_height[0])
  return dims
end

fn recorder_get_fps()
  return _rec_fps[0]
end

fn recorder_get_timestamps()
  return _rec_timestamps
end

fn recorder_clear()
  _rec_frame_offset[0] = len(_rec_frames)
  _rec_ts_offset[0] = len(_rec_timestamps)
  _rec_frame_count[0] = 0.0
  _rec_active[0] = 0.0
  return 0.0
end
