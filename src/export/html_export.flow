// html_export.flow — Export recorded frames as self-contained HTML
//
// Generates a single .html file that plays back the recorded visualization
// in any browser. No OctoFlow or server needed.
//
// Uses append_file for streaming writes — avoids O(n²) string concatenation.
// Hex encoding is inlined (no sub-function) because OctoFlow user-defined
// functions can only take number/array params, not strings.
//
// Usage:
//   use "src/export/html_export"
//   html_export_recording("output.html", "Heat Diffusion")

use "../recorder"

// Hex lookup: convert 0-15 to hex char
fn _hex_digit(n)
  let d = int(n) % 16
  if d == 0.0
    return "0"
  elif d == 1.0
    return "1"
  elif d == 2.0
    return "2"
  elif d == 3.0
    return "3"
  elif d == 4.0
    return "4"
  elif d == 5.0
    return "5"
  elif d == 6.0
    return "6"
  elif d == 7.0
    return "7"
  elif d == 8.0
    return "8"
  elif d == 9.0
    return "9"
  elif d == 10.0
    return "a"
  elif d == 11.0
    return "b"
  elif d == 12.0
    return "c"
  elif d == 13.0
    return "d"
  elif d == 14.0
    return "e"
  end
  return "f"
end

fn _byte_to_hex(val)
  let mut v = floor(val)
  if v < 0.0
    v = 0.0
  end
  if v > 255.0
    v = 255.0
  end
  let hi = _hex_digit(floor(v / 16.0))
  let lo = _hex_digit(v)
  return hi + lo
end

fn html_export_recording(filename, title)
  let n_frames = recorder_frame_count()
  if n_frames == 0.0
    print("html_export: no frames to export")
    return 0.0
  end

  let dims = recorder_get_dimensions()
  let w = dims[0]
  let h = dims[1]
  let fps = recorder_get_fps()
  let n_pixels = w * h
  let n_values = n_pixels * 3.0

  let fw = str(floor(w))
  let fh = str(floor(h))
  let ff = str(floor(fps))
  let fn_str = str(floor(n_frames))
  let fmax = str(floor(n_frames - 1.0))

  print("html_export: encoding {fn_str} frames ({fw}x{fh}) to {filename}")

  // Write HTML header (small string, single write_file to create/truncate)
  let mut hdr = "<!DOCTYPE html>\n<html><head><meta charset='utf-8'>\n"
  hdr = hdr + "<title>" + title + " — LoomView Recording</title>\n"
  hdr = hdr + "<style>\n"
  hdr = hdr + "body{margin:0;background:#1a1a2e;color:#eee;font-family:monospace;display:flex;flex-direction:column;align-items:center;padding:20px}\n"
  hdr = hdr + "h1{color:#00d4aa;margin:10px 0}\n"
  hdr = hdr + "canvas{border:1px solid #333;image-rendering:pixelated;margin:10px 0}\n"
  hdr = hdr + ".controls{display:flex;gap:10px;align-items:center;margin:10px 0}\n"
  hdr = hdr + "button{background:#00d4aa;color:#1a1a2e;border:none;padding:8px 16px;cursor:pointer;font-family:monospace;font-weight:bold;border-radius:4px}\n"
  hdr = hdr + "button:hover{background:#00ffcc}\n"
  hdr = hdr + "input[type=range]{width:300px}\n"
  hdr = hdr + ".info{color:#888;font-size:12px}\n"
  hdr = hdr + "</style></head><body>\n"
  hdr = hdr + "<h1>" + title + "</h1>\n"
  hdr = hdr + "<canvas id='c' width='" + fw + "' height='" + fh + "' style='width:" + str(floor(w * 4.0)) + "px;height:" + str(floor(h * 4.0)) + "px'></canvas>\n"
  hdr = hdr + "<div class='controls'>\n"
  hdr = hdr + "<button id='play'>Play</button>\n"
  hdr = hdr + "<span id='frame'>0 / " + fn_str + "</span>\n"
  hdr = hdr + "<input type='range' id='scrub' min='0' max='" + fmax + "' value='0'>\n"
  hdr = hdr + "<label>Speed: <select id='speed'><option>0.5x</option><option selected>1x</option><option>2x</option><option>4x</option></select></label>\n"
  hdr = hdr + "</div>\n"
  hdr = hdr + "<div class='info'>Recorded with LoomView | " + fn_str + " frames @ " + ff + " FPS | " + fw + "x" + fh + "</div>\n"
  hdr = hdr + "<script>\n"
  hdr = hdr + "const W=" + fw + ",H=" + fh + ",FPS=" + ff + ",N=" + fn_str + ";\n"
  hdr = hdr + "const frames=[\n"
  let _w = write_file(filename, hdr)

  // Stream frame data to file — chunked hex encoding inlined here
  // (can't pass filename to a sub-function; OctoFlow user fns only take numbers/arrays)
  let CHUNK_SIZE = 128.0
  let mut f = 0.0
  while f < n_frames
    let _q = append_file(filename, "'")
    let frame = recorder_get_frame(f)

    // Chunked hex encoding: build small strings and append each
    let mut p = 0.0
    while p < n_values
      let mut chunk = ""
      let chunk_end = p + CHUNK_SIZE
      while p < n_values && p < chunk_end
        let mut v = 0.0
        if int(p) < len(frame)
          v = frame[int(p)]
        end
        chunk = chunk + _byte_to_hex(v)
        p = p + 1.0
      end
      let _a = append_file(filename, chunk)
    end

    if f < n_frames - 1.0
      let _c = append_file(filename, "',\n")
    else
      let _c = append_file(filename, "'\n")
    end

    let fc = str(floor(f + 1.0))
    print("  html: frame {fc}/{fn_str} encoded")
    f = f + 1.0
  end

  // Write JavaScript player (small string, single append)
  let mut js = "];\n"
  js = js + "const cv=document.getElementById('c'),ctx=cv.getContext('2d');\n"
  js = js + "const img=ctx.createImageData(W,H);\n"
  js = js + "let cur=0,playing=false,speed=1;\n"
  js = js + "function hexToByte(h,i){const c=h.charCodeAt(i);return(c<58?c-48:c-87)*16+(h2=h.charCodeAt(i+1),h2<58?h2-48:h2-87)}\n"
  js = js + "function showFrame(f){\n"
  js = js + "  const d=frames[f],px=img.data;\n"
  js = js + "  for(let i=0;i<W*H;i++){px[i*4]=hexToByte(d,i*6);px[i*4+1]=hexToByte(d,i*6+2);px[i*4+2]=hexToByte(d,i*6+4);px[i*4+3]=255}\n"
  js = js + "  ctx.putImageData(img,0,0);\n"
  js = js + "  document.getElementById('frame').textContent=f+' / '+N;\n"
  js = js + "  document.getElementById('scrub').value=f;\n"
  js = js + "}\n"
  js = js + "function tick(){if(!playing)return;cur=(cur+1)%N;showFrame(cur);setTimeout(tick,1000/(FPS*speed))}\n"
  js = js + "document.getElementById('play').onclick=function(){playing=!playing;this.textContent=playing?'Pause':'Play';if(playing)tick()};\n"
  js = js + "document.getElementById('scrub').oninput=function(){cur=+this.value;showFrame(cur)};\n"
  js = js + "document.getElementById('speed').onchange=function(){speed=parseFloat(this.value)};\n"
  js = js + "showFrame(0);\n"
  js = js + "</script></body></html>"
  let _j = append_file(filename, js)

  print("html_export: done ({filename})")
  return 1.0
end
