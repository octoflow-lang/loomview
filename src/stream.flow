// stream.flow — Live Data Streaming from Loom VMs
//
// Connects to a running Loom VM and reads data from its globals buffer
// at a configurable poll rate. Auto-detects shape changes.
//
// Usage:
//   use "src/stream"
//   stream_start(30.0)              // 30 Hz polling
//   let data = stream_read()         // get latest data
//   if stream_changed() == 1.0
//     // data shape changed, re-fingerprint
//   end
//   stream_stop()

use "data"

// === Stream State ===
// Single-element arrays for cross-module mutation visibility.
let mut _stream_active = [0.0]
let mut _stream_poll_hz = [30.0]
let mut _stream_poll_interval_ms = [33.0]
let mut _stream_last_poll_ms = [0.0]
let mut _stream_data = []
let mut _stream_prev_len = [0.0]
let mut _stream_changed = [0.0]
let mut _stream_frame_count = [0.0]

// Fingerprint cache for change detection
let mut _stream_prev_fp = []

fn stream_start(poll_hz)
  let mut hz = poll_hz
  if hz <= 0.0
    hz = 30.0
  end
  if hz > 120.0
    hz = 120.0
  end

  _stream_poll_hz[0] = hz
  _stream_poll_interval_ms[0] = 1000.0 / hz
  _stream_active[0] = 1.0
  _stream_prev_len[0] = 0.0
  _stream_changed[0] = 0.0
  _stream_frame_count[0] = 0.0

  print("Stream: started at {hz} Hz")
  return 1.0
end

fn stream_stop()
  _stream_active[0] = 0.0
  let fc = _stream_frame_count[0]
  print("Stream: stopped after {fc} frames")
  return fc
end

fn stream_is_active()
  return _stream_active[0]
end

fn stream_poll(current_ms)
  if _stream_active[0] == 0.0
    return 0.0
  end

  // Rate limiting
  let elapsed = current_ms - _stream_last_poll_ms[0]
  if elapsed < _stream_poll_interval_ms[0] && _stream_frame_count[0] > 0.0
    return 0.0
  end

  // Read from Loom globals buffer
  let data = loom_read_globals()
  let n = len(data)

  // Detect shape change
  _stream_changed[0] = 0.0
  if n != _stream_prev_len[0]
    _stream_changed[0] = 1.0
    _stream_prev_len[0] = n
  end

  // Quick fingerprint comparison (just check min/max/mean)
  if n > 0.0 && _stream_changed[0] == 0.0
    let fp = viz_fingerprint(data)
    if len(_stream_prev_fp) == 16.0
      // Compare key dimensions
      let mut min_diff = fp[1] - _stream_prev_fp[1]
      let mut max_diff = fp[2] - _stream_prev_fp[2]
      let mut mean_diff = fp[3] - _stream_prev_fp[3]
      if min_diff < 0.0
        min_diff = 0.0 - min_diff
      end
      if max_diff < 0.0
        max_diff = 0.0 - max_diff
      end
      if mean_diff < 0.0
        mean_diff = 0.0 - mean_diff
      end
      if min_diff > 0.001 || max_diff > 0.001 || mean_diff > 0.001
        _stream_changed[0] = 1.0
      end
    end
    _stream_prev_fp = fp
  end

  _stream_data = data
  _stream_last_poll_ms[0] = current_ms
  _stream_frame_count[0] = _stream_frame_count[0] + 1.0

  return 1.0
end

fn stream_read()
  return _stream_data
end

fn stream_changed()
  return _stream_changed[0]
end

fn stream_frame_count()
  return _stream_frame_count[0]
end

fn stream_get_fingerprint()
  if len(_stream_prev_fp) == 16.0
    return _stream_prev_fp
  end
  return viz_fingerprint(_stream_data)
end
