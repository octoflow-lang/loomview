// config.flow — Auto-Configuration from Data Fingerprint
//
// Generates a config array for rendering based on data + viz type.
// Config: [x_min, x_max, y_min, y_max, palette_id, grid_w, grid_h, n_bins, padding, show_grid]
//
// Usage:
//   use "src/config"
//   let config = viz_auto_config(data, VIZ_LINE)

use "data"
use "palette"

fn _vc_min(arr)
  let n = len(arr)
  if n == 0.0
    return 0.0
  end
  let mut m = arr[0]
  let mut i = 1.0
  while i < n
    if arr[int(i)] < m
      m = arr[int(i)]
    end
    i = i + 1.0
  end
  return m
end

fn _vc_max(arr)
  let n = len(arr)
  if n == 0.0
    return 0.0
  end
  let mut m = arr[0]
  let mut i = 1.0
  while i < n
    if arr[int(i)] > m
      m = arr[int(i)]
    end
    i = i + 1.0
  end
  return m
end

fn _vc_log2(x)
  if x <= 0.0
    return 0.0
  end
  let mut result = 0.0
  let mut val = x
  while val >= 2.0
    val = val / 2.0
    result = result + 1.0
  end
  result = result + (val - 1.0)
  return result
end

fn viz_auto_config(data, viz_type)
  let mut config = [0.0, 1.0, 0.0, 1.0, 1.0, 10.0, 10.0, 10.0, 30.0, 1.0]

  let n = len(data)
  if n == 0.0
    return config
  end

  let fp = viz_fingerprint(data)
  let pal_id = viz_palette_auto(fp)
  config[4] = pal_id
  config[8] = 30.0
  config[9] = 1.0

  if viz_type == VIZ_LINE || viz_type == VIZ_SPARKLINE
    config[0] = 0.0
    config[1] = n - 1.0
    if config[1] <= 0.0
      config[1] = 1.0
    end
    let y_min = _vc_min(data)
    let y_max = _vc_max(data)
    let y_range = y_max - y_min
    let mut y_pad = y_range * 0.1
    if y_pad == 0.0
      y_pad = 1.0
    end
    config[2] = y_min - y_pad
    config[3] = y_max + y_pad

  elif viz_type == VIZ_BAR
    config[0] = 0.0
    config[1] = n
    let y_min = _vc_min(data)
    let y_max = _vc_max(data)
    config[2] = 0.0
    if y_min < 0.0
      config[2] = y_min * 1.1
    end
    config[3] = y_max * 1.1
    if config[3] <= 0.0
      config[3] = 1.0
    end

  elif viz_type == VIZ_HEATMAP
    let sqrt_n = floor(sqrt(n))
    if sqrt_n <= 0.0
      config[5] = 1.0
      config[6] = n
    else
      let mut best_w = sqrt_n
      let mut best_h = floor(n / sqrt_n)
      if best_w * best_h != n
        let mut w = sqrt_n + 1.0
        while w <= n
          let h = n / w
          if floor(h) == h
            best_w = w
            best_h = h
            w = n + 1.0
          end
          w = w + 1.0
          if w > sqrt_n + 10.0
            w = n + 1.0
          end
        end
      end
      config[5] = best_w
      config[6] = best_h
    end

  elif viz_type == VIZ_SCATTER || viz_type == VIZ_PARTICLES
    let n_pts = floor(n / 2.0)
    if n_pts > 0.0
      let mut x_min = data[0]
      let mut x_max = data[0]
      let mut y_min = data[1]
      let mut y_max = data[1]
      let mut i = 0.0
      while i < n_pts
        let px = data[int(i * 2.0)]
        let py = data[int(i * 2.0 + 1.0)]
        if px < x_min
          x_min = px
        end
        if px > x_max
          x_max = px
        end
        if py < y_min
          y_min = py
        end
        if py > y_max
          y_max = py
        end
        i = i + 1.0
      end
      let x_range = x_max - x_min
      let y_range = y_max - y_min
      let mut x_pad = x_range * 0.1
      let mut y_pad = y_range * 0.1
      if x_pad == 0.0
        x_pad = 1.0
      end
      if y_pad == 0.0
        y_pad = 1.0
      end
      config[0] = x_min - x_pad
      config[1] = x_max + x_pad
      config[2] = y_min - y_pad
      config[3] = y_max + y_pad
    end

  elif viz_type == VIZ_HISTOGRAM
    let mut bins = 1.0 + 3.322 * _vc_log2(n)
    bins = floor(bins) + 1.0
    if bins < 5.0
      bins = 5.0
    end
    if bins > 50.0
      bins = 50.0
    end
    config[7] = bins

  elif viz_type == VIZ_PIE
    config[8] = 20.0

  elif viz_type == VIZ_GRID
    let sqrt_n = floor(sqrt(n))
    if sqrt_n <= 0.0
      config[5] = 1.0
      config[6] = n
    else
      config[5] = sqrt_n
      config[6] = floor(n / sqrt_n)
      if config[5] * config[6] < n
        config[6] = config[6] + 1.0
      end
    end

  elif viz_type == VIZ_GENOME
    config[8] = 10.0
  end

  return config
end

fn viz_config_set(config, key, value)
  let idx = int(key)
  if idx >= 0.0 && idx < len(config)
    config[idx] = value
  end
  return config
end

fn viz_config_get(config, key)
  let idx = int(key)
  if idx >= 0.0 && idx < len(config)
    return config[idx]
  end
  return 0.0
end
