// recipe_nbody.flow — N-Body Gravitational Simulation Recipe
//
// Simulates N gravitating particles using Euler integration.
// Custom particle renderer with mass-based sizing.
// Softened gravity prevents singularities.
//
// Usage:
//   use "recipes/recipe_nbody"
//   recipe_nbody_run(100)

use "gui/gui_core"
use "gui/canvas"
use "src/data"
use "src/config"
use "src/render"
use "src/app"
use "src/palette"

let NBODY_FIELDS = 5.0

fn recipe_nbody_init(n)
  let mut nb = n
  if nb < 2.0
    nb = 2.0
  end
  if nb > 500.0
    nb = 500.0
  end

  let mut state = []
  push(state, nb)
  push(state, 1.0)
  push(state, 0.5)

  let mut i = 0.0
  while i < nb
    let angle = i / nb * 6.283185
    let radius = 3.0 + (i / nb) * 5.0
    let x = radius * cos(angle)
    let y = radius * sin(angle)

    let mut safe_radius = radius
    if safe_radius < 0.01
      safe_radius = 0.01
    end
    let speed = 0.3 * sqrt(nb / safe_radius)
    let vx = 0.0 - speed * sin(angle)
    let vy = speed * cos(angle)

    let mass = 1.0

    push(state, x)
    push(state, y)
    push(state, vx)
    push(state, vy)
    push(state, mass)

    i = i + 1.0
  end

  // Central massive body
  state[3] = 0.0
  state[4] = 0.0
  state[5] = 0.0
  state[6] = 0.0
  state[7] = nb * 2.0

  return state
end

fn recipe_nbody_step(state, dt)
  let n_state = len(state)
  if n_state < 4.0
    return state
  end

  let n = state[0]
  let big_g = state[1]
  let soft = state[2]
  let soft_sq = soft * soft

  let expected = 3.0 + n * NBODY_FIELDS
  if n_state < expected
    return state
  end

  if dt <= 0.0
    return state
  end
  // Clamp dt to prevent Euler integration blowup at high speeds
  let mut clamped_dt = dt
  if clamped_dt > 0.05
    clamped_dt = 0.05
  end

  // Compute accelerations
  let mut acc = []
  let mut i = 0.0
  while i < n
    push(acc, 0.0)
    push(acc, 0.0)
    i = i + 1.0
  end

  i = 0.0
  while i < n
    let i_base = int(3.0 + i * NBODY_FIELDS)
    let xi = state[i_base]
    let yi = state[i_base + 1]

    let mut j = i + 1.0
    while j < n
      let j_base = int(3.0 + j * NBODY_FIELDS)
      let xj = state[j_base]
      let yj = state[j_base + 1]
      let mj = state[j_base + 4]
      let mi = state[i_base + 4]

      let dx = xj - xi
      let dy = yj - yi
      let dist_sq = dx * dx + dy * dy + soft_sq

      if dist_sq > 0.0001
        let inv_dist = 1.0 / sqrt(dist_sq)
        let inv_dist3 = inv_dist * inv_dist * inv_dist

        let fx = big_g * dx * inv_dist3
        let fy = big_g * dy * inv_dist3

        let ai = int(i * 2.0)
        let aj = int(j * 2.0)
        acc[ai] = acc[ai] + fx * mj
        acc[ai + 1] = acc[ai + 1] + fy * mj
        acc[aj] = acc[aj] - fx * mi
        acc[aj + 1] = acc[aj + 1] - fy * mi
      end

      j = j + 1.0
    end
    i = i + 1.0
  end

  // Euler integration
  let mut next = []
  push(next, n)
  push(next, big_g)
  push(next, soft)

  i = 0.0
  while i < n
    let i_base = int(3.0 + i * NBODY_FIELDS)
    let ai = int(i * 2.0)

    let x = state[i_base]
    let y = state[i_base + 1]
    let vx = state[i_base + 2]
    let vy = state[i_base + 3]
    let mass = state[i_base + 4]

    let mut new_vx = vx + acc[ai] * clamped_dt
    let mut new_vy = vy + acc[ai + 1] * clamped_dt
    // Clamp velocities to prevent particles flying to infinity
    if new_vx > 50.0
      new_vx = 50.0
    end
    if new_vx < -50.0
      new_vx = -50.0
    end
    if new_vy > 50.0
      new_vy = 50.0
    end
    if new_vy < -50.0
      new_vy = -50.0
    end
    let new_x = x + new_vx * clamped_dt
    let new_y = y + new_vy * clamped_dt

    push(next, new_x)
    push(next, new_y)
    push(next, new_vx)
    push(next, new_vy)
    push(next, mass)

    i = i + 1.0
  end

  return next
end

fn recipe_nbody_render(cvs, state, config, cw, ch)
  let n_state = len(state)
  if n_state < 4.0
    return 0.0
  end

  let n = state[0]
  let _c = gui_canvas_clear(cvs)
  let _bg = gui_canvas_fill(cvs, 0.0, 0.0, cw, ch, 5.0, 5.0, 15.0)

  // Find bounding box
  let mut x_min = 0.0
  let mut x_max = 0.0
  let mut y_min = 0.0
  let mut y_max = 0.0
  let mut first = 1.0
  let mut i = 0.0
  while i < n
    let base = int(3.0 + i * NBODY_FIELDS)
    if base + 1 < n_state
      let px = state[base]
      let py = state[base + 1]
      if first == 1.0
        x_min = px
        x_max = px
        y_min = py
        y_max = py
        first = 0.0
      else
        if px < x_min
          x_min = px
        end
        if px > x_max
          x_max = px
        end
        if py < y_min
          y_min = py
        end
        if py > y_max
          y_max = py
        end
      end
    end
    i = i + 1.0
  end

  let x_range = x_max - x_min
  let y_range = y_max - y_min
  let mut x_pad = x_range * 0.15
  let mut y_pad = y_range * 0.15
  if x_pad < 1.0
    x_pad = 1.0
  end
  if y_pad < 1.0
    y_pad = 1.0
  end
  x_min = x_min - x_pad
  x_max = x_max + x_pad
  y_min = y_min - y_pad
  y_max = y_max + y_pad
  let mut x_total = x_max - x_min
  let mut y_total = y_max - y_min

  if x_total <= 0.0
    x_total = 1.0
  end
  if y_total <= 0.0
    y_total = 1.0
  end

  let margin = 20.0
  let pw = cw - margin * 2.0
  let ph = ch - margin * 2.0

  // Draw particles
  i = 0.0
  while i < n
    let base = int(3.0 + i * NBODY_FIELDS)
    if base + 4 < n_state
      let px = state[base]
      let py = state[base + 1]
      let mass = state[base + 4]

      let sx = margin + (px - x_min) / x_total * pw
      let sy = margin + ph - (py - y_min) / y_total * ph

      let mut radius = 2.0 + sqrt(mass) * 0.5
      if radius > 15.0
        radius = 15.0
      end

      let mut cr = 80.0
      let mut cg = 150.0
      let mut cb = 255.0
      if mass > 5.0
        cr = 255.0
        cg = 220.0
        cb = 80.0
      elif mass > 2.0
        cr = 200.0
        cg = 100.0
        cb = 200.0
      end

      let _d = gui_canvas_fill_circle(cvs, sx, sy, radius, cr, cg, cb)
    end
    i = i + 1.0
  end

  return 1.0
end

fn recipe_nbody_run(n)
  let mut nb = n
  if nb < 2.0
    nb = 2.0
  end
  if nb > 500.0
    nb = 500.0
  end

  print("LoomView Recipe: N-Body Simulation ({nb} bodies)")

  let mut state = recipe_nbody_init(nb)

  let _cvs = app_open("LoomView - N-Body Simulation", 1000.0, 700.0)
  app_add_transport()
  app_add_record_button()

  let _g_s = app_add_slider("Gravity", 0.1, 5.0, 1.0)
  let _soft_s = app_add_slider("Softening", 0.1, 2.0, 0.5)

  let canvas = app_canvas()
  let cs = app_canvas_size()
  let canvas_w = cs[0]
  let canvas_h = cs[1]

  let mut config = []

  let _r = recipe_nbody_render(canvas, state, config, canvas_w, canvas_h)

  let mut step_count = 0.0
  while app_running() == 1.0
    gui_update()

    let playing = app_is_playing()
    let speed = app_speed()

    if playing == 1.0
      let g_val = app_get_slider(0.0)
      let soft_val = app_get_slider(1.0)
      if g_val > 0.0
        state[1] = g_val
      end
      if soft_val > 0.0
        state[2] = soft_val
      end

      let dt = 0.02 * speed
      state = recipe_nbody_step(state, dt)
      step_count = step_count + 1.0

      let _r2 = recipe_nbody_render(canvas, state, config, canvas_w, canvas_h)
    end
  end

  print("N-body simulation ended after {step_count} steps")
  return state
end
