// recipe_wave.flow — 2D Wave Propagation Visualization Recipe
//
// Simulates the wave equation on a 2D grid using finite differences.
// Three-buffer rotation for second-order PDE.
//
// Usage:
//   use "recipes/recipe_wave"
//   recipe_wave_run(60, 40)

use "gui/gui_core"
use "gui/canvas"
use "src/data"
use "src/config"
use "src/render"
use "src/app"
use "src/palette"

fn recipe_wave_init(w, h)
  let mut gw = w
  let mut gh = h
  if gw < 5.0
    gw = 5.0
  end
  if gh < 5.0
    gh = 5.0
  end

  let n = gw * gh
  let mut state = []
  push(state, gw)
  push(state, gh)
  push(state, 0.5)
  push(state, 0.998)

  // Current grid — Gaussian pulse in center
  let cx = floor(gw / 2.0)
  let cy = floor(gh / 2.0)
  let mut i = 0.0
  while i < n
    let row = floor(i / gw)
    let col = i - row * gw
    let dx = col - cx
    let dy = row - cy
    let dist_sq = dx * dx + dy * dy
    let mut val = 0.0
    if dist_sq < 25.0
      val = (25.0 - dist_sq) / 25.0
    end
    push(state, val)
    i = i + 1.0
  end

  // Previous grid — same as current (zero velocity)
  i = 0.0
  while i < n
    let idx = int(4.0 + i)
    push(state, state[idx])
    i = i + 1.0
  end

  return state
end

fn recipe_wave_step(state, dt)
  let n_state = len(state)
  if n_state < 5.0
    return state
  end

  let w = state[0]
  let h = state[1]
  let c = state[2]
  let damping = state[3]

  if w < 5.0 || h < 5.0
    return state
  end

  let n = w * h
  let cur_offset = 4.0
  let prev_offset = 4.0 + n

  if n_state < 4.0 + 2.0 * n
    return state
  end

  let c_sq = c * c

  let mut next = []
  push(next, w)
  push(next, h)
  push(next, c)
  push(next, damping)

  let mut row = 0.0
  while row < h
    let mut col = 0.0
    while col < w
      let idx_cur = int(cur_offset + row * w + col)
      let idx_prev = int(prev_offset + row * w + col)

      if row == 0.0 || row == h - 1.0 || col == 0.0 || col == w - 1.0
        push(next, 0.0)
      else
        let cur = state[idx_cur]
        let prev = state[idx_prev]
        let up = state[int(cur_offset + (row - 1.0) * w + col)]
        let down = state[int(cur_offset + (row + 1.0) * w + col)]
        let left = state[int(cur_offset + row * w + (col - 1.0))]
        let right = state[int(cur_offset + row * w + (col + 1.0))]

        let laplacian = up + down + left + right - 4.0 * cur
        let mut new_val = 2.0 * cur - prev + c_sq * laplacian
        new_val = new_val * damping

        if new_val > 2.0
          new_val = 2.0
        end
        if new_val < -2.0
          new_val = -2.0
        end
        push(next, new_val)
      end
      col = col + 1.0
    end
    row = row + 1.0
  end

  // Rotate: current -> previous
  let mut i = 0.0
  while i < n
    push(next, state[int(cur_offset + i)])
    i = i + 1.0
  end

  return next
end

fn recipe_wave_get_grid(state)
  let n_state = len(state)
  if n_state < 5.0
    return []
  end

  let w = state[0]
  let h = state[1]
  let n = w * h

  if n_state < 4.0 + n
    return []
  end

  let mut grid = []
  let mut i = 0.0
  while i < n
    push(grid, state[int(4.0 + i)])
    i = i + 1.0
  end
  return grid
end

fn recipe_wave_run(w, h)
  let mut rw = w
  let mut rh = h
  if rw < 5.0
    rw = 5.0
  end
  if rh < 5.0
    rh = 5.0
  end

  print("LoomView Recipe: Wave Propagation ({rw}x{rh})")

  let mut state = recipe_wave_init(rw, rh)
  let grid = recipe_wave_get_grid(state)

  let mut config = viz_auto_config(grid, VIZ_HEATMAP)
  config[4] = PAL_COOLWARM
  config[5] = rw
  config[6] = rh

  let _cvs = app_open("LoomView - Wave Propagation", 1000.0, 700.0)
  app_add_transport()
  app_add_record_button()

  let _speed_s = app_add_slider("Wave Speed", 0.1, 1.0, 0.5)
  let _damp_s = app_add_slider("Damping", 0.99, 1.0, 0.998)

  let _r = app_update(grid, VIZ_HEATMAP, config)

  let mut step_count = 0.0
  while app_running() == 1.0
    gui_update()

    let playing = app_is_playing()
    let speed = app_speed()

    if playing == 1.0
      let mut c_val = app_get_slider(0.0)
      let d_val = app_get_slider(1.0)
      // Clamp wave speed for numerical stability (c^2 must be <= 0.5)
      if c_val > 0.707
        c_val = 0.707
      end
      if c_val > 0.0
        state[2] = c_val
      end
      if d_val > 0.0
        state[3] = d_val
      end

      let mut steps = floor(speed)
      if steps < 1.0
        steps = 1.0
      end
      let mut s = 0.0
      while s < steps
        state = recipe_wave_step(state, 0.016)
        s = s + 1.0
      end
      step_count = step_count + steps

      let new_grid = recipe_wave_get_grid(state)
      let _r2 = app_update(new_grid, VIZ_HEATMAP, config)
    end
  end

  print("Wave simulation ended after {step_count} steps")
  return state
end
